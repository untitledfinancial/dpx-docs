---
// LiveDemo — four-step interactive agent payment demo
// All API calls run client-side. No backend, no API key.
---

<div class="demo-wrap">

  <!-- Step 1: Oracle -->
  <div class="demo-step" id="step-oracle">
    <div class="demo-step-header">
      <span class="demo-step-num">1</span>
      <div>
        <div class="demo-step-title">Oracle status</div>
        <div class="demo-step-sub">9-layer macro stability check — gates every settlement</div>
      </div>
      <span class="demo-badge" id="oracle-badge"></span>
    </div>
    <div class="demo-step-body">
      <div class="demo-response" id="oracle-response">
        <span class="demo-loading">Checking oracle…</span>
      </div>
      <button class="demo-btn demo-btn-secondary" id="oracle-refresh-btn">Refresh</button>
    </div>
  </div>

  <!-- Step 2: Quote -->
  <div class="demo-step" id="step-quote">
    <div class="demo-step-header">
      <span class="demo-step-num">2</span>
      <div>
        <div class="demo-step-title">Get a quote</div>
        <div class="demo-step-sub">Live fee calculation — valid for 300 seconds</div>
      </div>
      <span class="demo-badge" id="quote-badge"></span>
    </div>
    <div class="demo-step-body">
      <div class="demo-inputs-row">
        <div class="demo-field">
          <label class="demo-label" for="quote-amount">Amount (USD)</label>
          <div class="demo-input-prefix-wrap">
            <span class="demo-prefix">$</span>
            <input id="quote-amount" class="demo-input" type="number" value="50000" min="100" step="1000" />
          </div>
        </div>
        <div class="demo-field">
          <label class="demo-label" for="quote-fx">Cross-currency</label>
          <label class="demo-toggle">
            <input id="quote-fx" type="checkbox" />
            <span class="demo-toggle-track"></span>
            <span class="demo-toggle-label-text">FX overlay</span>
          </label>
        </div>
        <button class="demo-btn" id="quote-btn">Get quote</button>
      </div>
      <div class="demo-response demo-response--hidden" id="quote-response"></div>
    </div>
  </div>

  <!-- Step 3: Compliance -->
  <div class="demo-step" id="step-compliance">
    <div class="demo-step-header">
      <span class="demo-step-num">3</span>
      <div>
        <div class="demo-step-title">Compliance preflight</div>
        <div class="demo-step-sub">AML · sanctions · FATF R16 · ESG · routing — one call</div>
      </div>
      <span class="demo-badge" id="compliance-badge"></span>
    </div>
    <div class="demo-step-body">
      <div class="demo-inputs-row">
        <div class="demo-field demo-field--wide">
          <label class="demo-label" for="comp-name">Counterparty name</label>
          <input id="comp-name" class="demo-input" type="text" value="Berlin Supplier GmbH" />
        </div>
        <div class="demo-field demo-field--wide">
          <label class="demo-label" for="comp-lei">LEI (optional)</label>
          <input id="comp-lei" class="demo-input" type="text" placeholder="20-char LEI" />
        </div>
        <button class="demo-btn" id="compliance-btn">Run preflight</button>
      </div>
      <div class="demo-response demo-response--hidden" id="compliance-response"></div>
    </div>
  </div>

  <!-- Step 4: Settle -->
  <div class="demo-step" id="step-settle">
    <div class="demo-step-header">
      <span class="demo-step-num">4</span>
      <div>
        <div class="demo-step-title">Execute settlement</div>
        <div class="demo-step-sub">Full stack, no on-chain transaction — oracle, compliance, and fee math run live</div>
      </div>
      <span class="demo-badge" id="settle-badge"></span>
    </div>
    <div class="demo-step-body">
      <div class="demo-sandbox-note">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="currentColor"/><path d="M7 4v4M7 9.5v.5" stroke="currentColor" stroke-linecap="round"/></svg>
        Sandbox mode — full stack executes, nothing moves on-chain
      </div>
      <button class="demo-btn" id="settle-btn" disabled>Settle (sandbox)</button>
      <div class="demo-response demo-response--hidden" id="settle-response"></div>
    </div>
  </div>

</div>

<script is:inline>
const AGENT_URL      = 'https://agent.untitledfinancial.com';
const STABILITY_URL  = 'https://stability.untitledfinancial.com';

// ── Helpers ──────────────────────────────────────────────────────────────────

function show(id) {
  document.getElementById(id)?.classList.remove('demo-response--hidden');
}
function hide(id) {
  document.getElementById(id)?.classList.add('demo-response--hidden');
}

function setResponse(id, html) {
  const el = document.getElementById(id);
  if (el) el.innerHTML = html;
}

function setBadge(id, text, type) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = `demo-badge demo-badge--${type}`;
}

function kv(label, value) {
  return `<div class="demo-kv"><span class="demo-kv-label">${label}</span><span class="demo-kv-value">${value}</span></div>`;
}

function statusBadge(status) {
  const cls = status === 'STABLE' || status === 'PROCEED' ? 'ok'
    : status === 'CAUTION' || status === 'HOLD' ? 'warn' : 'block';
  return `<span class="demo-status demo-status--${cls}">${status}</span>`;
}

function fmt(v) {
  return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtPct(v) {
  return v.toFixed(4) + '%';
}

function setLoading(btnId, loading, label) {
  const btn = document.getElementById(btnId);
  if (!btn) return;
  btn.disabled = loading;
  btn.textContent = loading ? 'Running…' : label;
}

// ── Shared state ──────────────────────────────────────────────────────────────

let quoteId = null;
let compliancePassed = false;

// ── Step 1: Oracle ────────────────────────────────────────────────────────────

async function loadOracle() {
  const el = document.getElementById('oracle-response');
  el.innerHTML = '<span class="demo-loading">Checking oracle…</span>';
  show('oracle-response');
  try {
    const res  = await fetch(`${STABILITY_URL}/reliability`);
    const data = await res.json();
    const status = data.status ?? 'UNKNOWN';
    const score  = data.score ?? data.stabilityScore ?? 0;
    const type = status === 'STABLE' ? 'ok' : status === 'CAUTION' ? 'warn' : 'block';
    setBadge('oracle-badge', status, type);

    let html = kv('Status',  statusBadge(status));
    html    += kv('Score',   `${score} / 100`);
    if (data.recommendation) html += kv('Recommendation', data.recommendation);
    if (data.reasoning || data.briefing) {
      const text = (data.reasoning || data.briefing || '').substring(0, 300);
      html += `<div class="demo-reasoning">${text}${text.length === 300 ? '…' : ''}</div>`;
    }

    el.innerHTML = html;

    const quoteBtn = document.getElementById('quote-btn');
    if (quoteBtn) quoteBtn.disabled = status === 'UNSTABLE';
    if (status === 'UNSTABLE') {
      setBadge('oracle-badge', 'UNSTABLE — settlement held', 'block');
    }
  } catch(e) {
    el.innerHTML = `<span class="demo-error">Could not reach oracle: ${e.message}</span>`;
    setBadge('oracle-badge', 'error', 'block');
  }
}

document.getElementById('oracle-refresh-btn')?.addEventListener('click', loadOracle);

// ── Step 2: Quote ─────────────────────────────────────────────────────────────

document.getElementById('quote-btn')?.addEventListener('click', async () => {
  const amount = parseFloat(document.getElementById('quote-amount').value) || 50000;
  const hasFx  = document.getElementById('quote-fx').checked;

  setLoading('quote-btn', true, 'Get quote');
  hide('quote-response');
  quoteId = null;
  compliancePassed = false;
  const settleBtn = document.getElementById('settle-btn');
  if (settleBtn) settleBtn.disabled = true;
  setBadge('quote-badge', '', 'idle');
  setBadge('compliance-badge', '', 'idle');
  setBadge('settle-badge', '', 'idle');

  try {
    const url  = `${AGENT_URL}/quote?amountUsd=${amount}&hasFx=${hasFx}`;
    const res  = await fetch(url);
    const data = await res.json();

    const q = data.quote ?? data;
    quoteId  = q.quoteId ?? data.quoteId ?? null;

    const f        = q.fees ?? data.fees ?? {};
    const totalPct = f.total?.pct ?? f.total?.bps != null ? (f.total.bps / 100) : null;
    const totalUsd = f.total?.usd ?? null;
    const netUsd   = q.settlement?.netUsd ?? data.netAmountUsd ?? null;

    let html = kv('Amount', fmt(amount));
    if (totalPct !== null) html += kv('All-in fee', fmtPct(totalPct));
    if (totalUsd !== null) html += kv('Fee (USD)',   fmt(totalUsd));
    if (netUsd   !== null) html += kv('You receive', fmt(netUsd));
    if (quoteId)           html += kv('Quote ID',    `<code>${quoteId}</code>`);
    html += kv('Valid for', '300 seconds');

    setResponse('quote-response', html);
    show('quote-response');
    setBadge('quote-badge', 'quoted', 'ok');
  } catch(e) {
    setResponse('quote-response', `<span class="demo-error">${e.message}</span>`);
    show('quote-response');
    setBadge('quote-badge', 'error', 'block');
  } finally {
    setLoading('quote-btn', false, 'Get quote');
  }
});

// ── Step 3: Compliance ────────────────────────────────────────────────────────

document.getElementById('compliance-btn')?.addEventListener('click', async () => {
  const amount  = parseFloat((document.getElementById('quote-amount'))?.value) || 50000;
  const hasFx   = (document.getElementById('quote-fx'))?.checked;
  const name    = (document.getElementById('comp-name')).value.trim() || 'Berlin Supplier GmbH';
  const lei     = (document.getElementById('comp-lei')).value.trim();

  setLoading('compliance-btn', true, 'Run preflight');
  hide('compliance-response');
  compliancePassed = false;
  const settleBtn = document.getElementById('settle-btn');
  if (settleBtn) settleBtn.disabled = true;
  setBadge('compliance-badge', '', 'idle');
  setBadge('settle-badge', '', 'idle');

  try {
    const params = new URLSearchParams({
      amount:           String(amount),
      from:             'USD',
      to:               hasFx ? 'EUR' : 'USD',
      recipientAddress: '0x0000000000000000000000000000000000000001',
      counterpartyName: name,
    });
    if (lei) params.set('lei', lei);

    const res  = await fetch(`${AGENT_URL}/flow-check?${params}`);
    const data = await res.json();
    const decision = data.decision ?? data.status ?? 'BLOCKED';
    const type = decision === 'PROCEED' ? 'ok' : decision === 'HOLD' ? 'warn' : 'block';

    let html = kv('Decision', statusBadge(decision));
    if (data.blockReason || data.holdReason) {
      html += kv('Reason', data.blockReason ?? data.holdReason ?? '');
    }
    if (data.amlResult) {
      const a = data.amlResult;
      html += kv('AML', a.status ?? a.decision ?? '—');
      if (a.sanctionsHit !== undefined) html += kv('Sanctions hit', a.sanctionsHit ? 'YES' : 'No');
    }
    if (data.esgScore !== undefined) html += kv('ESG score', String(data.esgScore));
    if (data.settleBody?.token) html += kv('Routed via', data.settleBody.token);
    if (data.reasoning) {
      html += `<div class="demo-reasoning">${String(data.reasoning).substring(0, 300)}</div>`;
    }

    setResponse('compliance-response', html);
    show('compliance-response');
    setBadge('compliance-badge', decision, type);

    if (decision === 'PROCEED') {
      compliancePassed = true;
      if (settleBtn) settleBtn.disabled = false;
    }
  } catch(e) {
    setResponse('compliance-response', `<span class="demo-error">${e.message}</span>`);
    show('compliance-response');
    setBadge('compliance-badge', 'error', 'block');
  } finally {
    setLoading('compliance-btn', false, 'Run preflight');
  }
});

// ── Step 4: Settle ────────────────────────────────────────────────────────────

document.getElementById('settle-btn')?.addEventListener('click', async () => {
  const amount = parseFloat((document.getElementById('quote-amount'))?.value) || 50000;
  const hasFx  = (document.getElementById('quote-fx'))?.checked;

  setLoading('settle-btn', true, 'Settle (sandbox)');
  hide('settle-response');
  setBadge('settle-badge', '', 'idle');

  try {
    const body: Record<string, unknown> = {
      amount,
      sourceCurrency:      'USD',
      destinationCurrency: hasFx ? 'EUR' : 'USD',
      recipientAddress:    '0x0000000000000000000000000000000000000001',
      purpose:             'agent-payment',
      referenceId:         `demo-${Date.now()}`,
      sandbox:             true,
    };
    if (quoteId) body.quoteId = quoteId;

    const res  = await fetch(`${AGENT_URL}/settle`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();

    const id     = data.settlementId ?? data.simulatedId ?? data.id ?? '—';
    const status = data.status ?? '—';

    let html = kv('Status',    statusBadge(status === 'settled' || status === 'simulated' ? 'PROCEED' : status));
    html    += kv('Settlement ID', `<code>${id}</code>`);
    if (data.oracleStatus)  html += kv('Oracle at settlement', statusBadge(data.oracleStatus));
    if (data.token)         html += kv('Token', data.token);
    if (data.netUsd)        html += kv('Net received', fmt(data.netUsd));
    html    += kv('On-chain', 'No — sandbox mode');
    html    += `<div class="demo-reasoning demo-reasoning--success">Settlement complete. Set <code>sandbox: false</code> and supply a funded wallet to go live on Base mainnet.</div>`;

    setResponse('settle-response', html);
    show('settle-response');
    setBadge('settle-badge', 'settled', 'ok');
  } catch(e) {
    setResponse('settle-response', `<span class="demo-error">${e.message}</span>`);
    show('settle-response');
    setBadge('settle-badge', 'error', 'block');
  } finally {
    setLoading('settle-btn', false, 'Settle (sandbox)');
  }
});

// ── Auto-run oracle on load ───────────────────────────────────────────────────

loadOracle();
</script>

<style>
.demo-wrap {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0;
}

.demo-step {
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 8px;
  background: var(--sl-color-bg);
  overflow: hidden;
}

.demo-step-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  border-bottom: 1px solid var(--sl-color-gray-6);
  background: var(--sl-color-gray-7);
}

.demo-step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--sl-color-accent);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
}

.demo-step-title {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--sl-color-text);
}

.demo-step-sub {
  font-size: 0.75rem;
  color: var(--sl-color-gray-3);
  margin-top: 1px;
}

.demo-badge {
  margin-left: auto;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.demo-badge--ok    { background: #d1fae5; color: #065f46; }
.demo-badge--warn  { background: #fef3c7; color: #92400e; }
.demo-badge--block { background: #fee2e2; color: #991b1b; }
.demo-badge--idle  { display: none; }

@media (prefers-color-scheme: dark) {
  .demo-badge--ok    { background: #064e3b; color: #6ee7b7; }
  .demo-badge--warn  { background: #451a03; color: #fcd34d; }
  .demo-badge--block { background: #450a0a; color: #fca5a5; }
}

.demo-step-body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.demo-inputs-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 0.75rem;
}

.demo-field {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.demo-field--wide { flex: 1; min-width: 160px; }

.demo-label {
  font-size: 0.75rem;
  color: var(--sl-color-gray-2);
  font-weight: 500;
}

.demo-input-prefix-wrap {
  display: flex;
  align-items: center;
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 6px;
  overflow: hidden;
  background: var(--sl-color-bg);
}
.demo-prefix {
  padding: 0 0.5rem;
  font-size: 0.85rem;
  color: var(--sl-color-gray-3);
  background: var(--sl-color-gray-7);
  border-right: 1px solid var(--sl-color-gray-5);
  height: 100%;
  display: flex;
  align-items: center;
}

.demo-input {
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 6px;
  padding: 0.4rem 0.6rem;
  font-size: 0.85rem;
  background: var(--sl-color-bg);
  color: var(--sl-color-text);
  min-width: 0;
  width: 100%;
}
.demo-input-prefix-wrap .demo-input {
  border: none;
  border-radius: 0;
}

.demo-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  padding: 0.4rem 0;
}
.demo-toggle input { display: none; }
.demo-toggle-track {
  width: 32px;
  height: 18px;
  border-radius: 9px;
  background: var(--sl-color-gray-5);
  flex-shrink: 0;
  position: relative;
  transition: background 0.15s;
}
.demo-toggle-track::after {
  content: '';
  position: absolute;
  width: 14px; height: 14px;
  border-radius: 50%;
  background: #fff;
  top: 2px; left: 2px;
  transition: transform 0.15s;
}
.demo-toggle input:checked ~ .demo-toggle-track { background: var(--sl-color-accent); }
.demo-toggle input:checked ~ .demo-toggle-track::after { transform: translateX(14px); }
.demo-toggle-label-text { font-size: 0.82rem; color: var(--sl-color-text); }

.demo-btn {
  padding: 0.45rem 1rem;
  border-radius: 6px;
  border: none;
  background: var(--sl-color-accent);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  align-self: flex-end;
  transition: opacity 0.15s;
}
.demo-btn:disabled { opacity: 0.45; cursor: default; }
.demo-btn:hover:not(:disabled) { opacity: 0.85; }
.demo-btn-secondary {
  background: var(--sl-color-gray-6);
  color: var(--sl-color-text);
  align-self: flex-start;
  border: 1px solid var(--sl-color-gray-5);
}

.demo-response {
  font-size: 0.82rem;
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 6px;
  padding: 0.75rem;
  background: var(--sl-color-gray-7);
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.demo-response--hidden { display: none; }

.demo-kv {
  display: flex;
  gap: 0.75rem;
  align-items: baseline;
}
.demo-kv-label {
  color: var(--sl-color-gray-3);
  font-size: 0.75rem;
  min-width: 130px;
  flex-shrink: 0;
}
.demo-kv-value {
  color: var(--sl-color-text);
  font-family: var(--sl-font-mono, monospace);
  font-size: 0.82rem;
}

.demo-status {
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.04em;
}
.demo-status--ok    { background: #d1fae5; color: #065f46; }
.demo-status--warn  { background: #fef3c7; color: #92400e; }
.demo-status--block { background: #fee2e2; color: #991b1b; }
@media (prefers-color-scheme: dark) {
  .demo-status--ok    { background: #064e3b; color: #6ee7b7; }
  .demo-status--warn  { background: #451a03; color: #fcd34d; }
  .demo-status--block { background: #450a0a; color: #fca5a5; }
}

.demo-reasoning {
  margin-top: 0.5rem;
  padding: 0.5rem 0.6rem;
  background: var(--sl-color-bg);
  border-left: 3px solid var(--sl-color-gray-4);
  border-radius: 0 4px 4px 0;
  font-size: 0.78rem;
  color: var(--sl-color-gray-2);
  line-height: 1.5;
  font-family: var(--sl-font, inherit);
}
.demo-reasoning--success { border-color: var(--sl-color-accent); }

.demo-loading { color: var(--sl-color-gray-3); font-style: italic; }
.demo-error   { color: #dc2626; }

.demo-sandbox-note {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.76rem;
  color: var(--sl-color-gray-3);
}
</style>
