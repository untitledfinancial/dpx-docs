    "@ucanto/core": "^10.0.1",
    "@ucanto/principal": "^9.0.1",
    "@web3-storage/w3up-client": "^17.3.0",
    "astro": "^5.6.1",
    "dotenv": "^16.3.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "wrangler": "^4.67.0"
  }
}
